<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新加坡基本交通理论考试"
            android:textSize="16sp"
            android:textColor="@color/medium_gray"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvTotalQuestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/medium_gray"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Resume incomplete session card -->
        <LinearLayout
            android:id="@+id/layoutResumeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Start new session -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开始新练习"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart10"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="10 题"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart20"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="20 题"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart50"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="50 题"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Focused Practice Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="专项练习"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecentWrong"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="最近做错的题"
            android:textSize="15sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWithNumbers"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="含数字的题"
            android:textSize="15sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnattempted"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="没做过的题"
            android:textSize="15sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="24dp" />

        <!-- Browse question bank -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/view_history"
            android:textSize="15sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="24dp" />

        <!-- Session history -->
        <LinearLayout
            android:id="@+id/layoutSessionHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
